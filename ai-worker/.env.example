# Local buffer database on this Arch desktop
DATABASE_URL=postgresql://blindtest_user:blindtest_pass@localhost:5432/blindtest

# Remote databases on OptiPlex (reached via SSH tunnel on local port 5433)
REMOTE_RAW_DATABASE_URL=postgresql://blindtest_user:blindtest_pass@localhost:5433/blindtest_old
REMOTE_DATABASE_URL=postgresql://blindtest_user:blindtest_pass@localhost:5433/blindtest

# Ollama (local LLM server on this machine)
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2

# Batch processing
BATCH_SIZE=25
CONCURRENCY=5
POLL_INTERVAL_MS=60000

# Audio classification (optional — requires Python + dependencies)
AUDIO_CLASSIFICATION_ENABLED=false
AUDIO_MODEL_PATH=./models/musicnn.onnx

# Model version tag written to ai_version column
AI_VERSION=llama3.2-v1
