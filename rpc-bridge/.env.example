# Your Discord Application Client ID (from Discord Developer Portal)
# Must have Rich Presence enabled
DISCORD_CLIENT_ID=

# BlindTest backend URL
BLINDTEST_API_URL=http://localhost:3001

# BlindTest API token (copy from browser localStorage -> blindtest_token)
# Or set via --token CLI arg
BLINDTEST_TOKEN=

# Poll interval in ms (default 5000)
POLL_INTERVAL_MS=5000
