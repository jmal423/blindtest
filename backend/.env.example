# === Database (PostgreSQL) ===
DATABASE_URL=postgresql://dev_user:dev_password@localhost:5432/blindtest

# === Audio source: Deezer (free, no API key needed) ===
# No API keys required for music — Deezer is the default and only source

# === Authentication (Discord OAuth2) ===
# DISCORD_CLIENT_ID=your_discord_client_id
# DISCORD_CLIENT_SECRET=your_discord_client_secret
JWT_SECRET=change-me-in-production

# === Optional: Restrict to a specific Discord guild ===
# DISCORD_ALLOWED_GUILD_ID=1234567890

# === Optional: Admin users by Discord ID (comma-separated) ===
# ADMIN_DISCORD_IDS=1234567890,9876543210

# === Server ===
PORT=3001

# === Frontend URL (for CORS, OAuth redirects) ===
# FRONTEND_URL=https://your-frontend.vercel.app
